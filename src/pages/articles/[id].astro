---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { marked } from 'marked';

// 使用 import.meta.glob 获取所有文章
const posts = import.meta.glob('../../content/posts/*.md', { eager: true });

// 生成静态路径
export function getStaticPaths() {
  const paths = Object.entries(posts).map(([path, post]: [string, any]) => {
    // 从 frontmatter 中获取 id，如果没有则从文件名提取
    const id = post.frontmatter?.id || path.split('/').pop()?.replace('.md', '');
    return {
      params: { id },
      props: { post }
    };
  });
  
  // 如果没有文章，返回空数组
  return paths.length > 0 ? paths : [];
}

// 获取当前文章的 props
const { post } = Astro.props;

// 如果文章不存在，显示 404
if (!post) {
  return Astro.redirect('/404');
}

const { title, category, tags, publishTime, source } = post.frontmatter;

// 获取分类名称
function getCategoryName(cat: string) {
  const names: Record<string, string> = {
    'guokao': '国考资料',
    'shengkao': '省考资料',
    'xingce': '行测',
    'shenlun': '申论',
    'mianshi': '面试',
    'planning': '备考规划',
    'general': '综合资讯'
  };
  return names[cat] || '综合资讯';
}
---

<Layout title={`${title} - 公考资料网`} description={post.frontmatter.excerpt || title}>
  <Header />
  
  <main class="main-content">
    <div class="container">
      <div class="article-detail">
        <article>
          <header class="article-header">
            <h1>{title}</h1>
            <div class="article-meta">
              <span>分类：{getCategoryName(category)}</span>
              <span>发布时间：{new Date(publishTime).toLocaleDateString('zh-CN')}</span>
              <span>来源：{source}</span>
            </div>
            <div class="article-tags">
              {tags?.map((tag: string) => <span class="tag">{tag}</span>)}
            </div>
          </header>
          <div class="article-content" set:html={marked.parse(post.rawContent())} />
        </article>
        
        <aside class="article-sidebar">
          <div class="widget">
            <h3>关注我们</h3>
            <p>扫码添加企业微信，获取更多公考资料</p>
            <img src="/images/wechat-qr.png" alt="企业微信二维码" class="qr-code" />
          </div>
          <div class="widget">
            <h3>推荐资料</h3>
            <ul class="resource-list">
              <li><a href="/guokao.html">国考历年真题</a></li>
              <li><a href="/shenlun.html">申论答题模板</a></li>
              <li><a href="/xingce.html">行测高频考点</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
